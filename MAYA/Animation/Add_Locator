import maya.cmds as cmds

def create_locator_at_pivot():
    # Get selected objects
    selection = cmds.ls(selection=True, long=True)

    if not selection:
        cmds.warning("No object selected.")
        return

    created_locators = []

    for obj in selection:
        # Get world-space rotate pivot position
        pivot_position = cmds.xform(obj, query=True, worldSpace=True, rotatePivot=True)

        # Get world-space rotation
        rotation = cmds.xform(obj, query=True, worldSpace=True, rotation=True)

        # Create locator
        locator = cmds.spaceLocator(name=f"{obj.split('|')[-1]}_pivot_loc")[0]

        # Move locator to pivot position
        cmds.xform(locator, worldSpace=True, translation=pivot_position)

        # Match locator rotation to object rotation
        cmds.xform(locator, worldSpace=True, rotation=rotation)

        created_locators.append(locator)

    # Select created locators
    cmds.select(created_locators)

    print("Done: Locators created at pivot points.")

# Execute function
create_locator_at_pivot()
